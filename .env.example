# MongoDB Atlas PoC Locust — Localized runs
# Copy to .env and fill in values. Do not commit .env or real credentials.

# Required: MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# Required: Database name
MONGODB_DATABASE=poc_demo

# Optional: Primary collection (script 01, 02, 04). Default: duns
# For script 02 use one of: suits | liens | judgments | uccs | bankruptcies
MONGODB_COLLECTION=duns

# Optional: Seed script bulk sizes. Default: 500 (01), 200 (02)
LOCUST_BULK_SIZE=500

# Optional: Search script candidate limit. Default: 10
LOCUST_CANDIDATE_LIMIT=10

# Optional: Ops script bulk file size. Default: 50
LOCUST_BULK_FILE_SIZE=50

# Optional: Search script collection names (script 03)
# MONGODB_CORE_COLLECTION=duns
# MONGODB_TRADE_COLLECTION=entity_trade
# MONGODB_PUBLIC_RECORDS_COLLECTIONS=suits,liens,judgments,uccs,bankruptcies
